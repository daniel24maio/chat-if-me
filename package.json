{
  "name": "monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web & npm run dev:api",
    "dev:web": "npm --prefix packages/web run dev",
    "dev:api": "npm --prefix packages/api run dev"
  },
  "dependencies": {
    "mammoth": "^1.12.0",
    "xlsx": "^0.18.5"
  }
}
