# ── Servidor ──
PORT=3333

# ── CORS ──
# Origens permitidas (separadas por vírgula). Em produção, use o domínio do Cloudflare.
CORS_ORIGINS=http://localhost:5173

# ── Segurança ──
# Chave de API para rotas admin (/api/embedding). Gere uma chave forte.
ADMIN_API_KEY=TROCAR_POR_UMA_CHAVE_SEGURA

# ── PostgreSQL (com pgvector habilitado) ──
DATABASE_URL=postgresql://USUARIO:SENHA@localhost:5432/chatifme

# ── Ollama ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=bge-m3
OLLAMA_LLM_MODEL=qwen3.5:2b-q4_K_M
OLLAMA_REWRITE_MODEL=qwen3.5:2b-q4_K_M

# ── Redis (para BullMQ) ──
REDIS_URL=redis://localhost:6379
